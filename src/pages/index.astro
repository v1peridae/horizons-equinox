---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<header class="text-white relative h-screen flex flex-col justify-center items-center overflow-hidden px-4 py-8 md:py-12">
		<img class="absolute inset-0 w-full h-full object-cover z-0" src="/header_bg.webp" alt="Horizons Equinox Background" />
		<div class="absolute inset-0 bg-linear-to-t from-black via-black/83 to-transparent z-0"></div>

		<div class="relative z-10 w-full max-w-4xl text-center hero-boot">
<img src="/equinox_logo.webp" alt="equinoxlogo" class="w-[min(95vw,40rem)] md:w-[min(90vw,42rem)] mx-auto mb-3 md:mb-4 shake-logo">
			<div class="text-white">
				<h1 class="font-futura text-xl sm:text-2xl md:text-[3rem] md:leading-tight font-bold mb-2 md:mb-4 px-1">August 14-16 @ The GrEEK Campus, CAIRO, EGYPT</h1>
				<h2 class="font-futura text-base sm:text-lg md:text-3xl mt-2 font-normal">Code for 35 hours, <br class="hidden sm:block" /> Get invited to a 3-day hackathon adventure</h2>
			</div>

			<div class="relative mt-4 md:mt-8 flex justify-center">
  <div class="p-0.5 rounded-full bg-[#EC7A0F] inline-block">
    <a href="https://horizons.hackclub.com" class="font-futura text-lg sm:text-xl md:text-2xl font-bold bg-black text-[#ec7a0f] px-6 sm:px-8 md:px-14 py-2 rounded-full flex items-center justify-center w-full h-full relative z-10">
      get started!
    </a>
  </div>
</div>
		</div>


	</header>
		<main id="intro" class="bg-black text-white px-4 pt-12 md:pt-10 pb-0 text-center relative overflow-hidden">

		<section class="max-w-5xl mx-auto relative px-4">
			<img src="/asset4.webp" alt="ankh" class="hidden md:block absolute -left-30 top-40 w-[24%] shake-on-hover" tabindex="0">			<p class="font-futura text-xl sm:text-2xl md:text-5xl leading-snug md:leading-tight mb-10 md:mb-16">
				This August, we are bringing together 60+ teen coders from all around the world to join us for a free 3-day hackathon adventure in Egypt, <b>Horizons Equinox</b>.
			</p>
			<h1 class="font-karim text-5xl sm:text-6xl md:text-[9.5rem] py-0 mb-2 md:mb-0 text-center break-words">
				All for free!
			</h1>
			<p class="font-futura text-lg md:text-2xl leading-tight mb-12 md:mb-16">
				Free meals & snacks * Local transport * Event swag <br class="hidden md:block">
				Flight stipends available for extra hours
			</p>
		</section>


<section class="px-4">
  <div class="relative w-full md:w-[70%] mx-auto min-h-[240px] sm:min-h-[280px] md:min-h-0">
    <img src="/background.webp" alt="how to qualify" class="w-full block select-none pointer-events-auto transition-transform duration-200 ease-out will-change-transform hover:scale-[1.08] hover:-translate-y-2" />
    <div class="absolute inset-x-0 top-0 flex justify-center">
      <div class="relative w-full">
       <img src="/signup.webp" alt="sign up" class="absolute left-0 top-0 block w-[70%] select-none pointer-events-auto transition-transform duration-200 ease-out will-change-transform hover:scale-[1.08] hover:-translate-y-2"/>

<img
  src="/codefor.webp"
  alt="code for 35"
  class="absolute right-0 top-0 w-[50%] -translate-y-3 block select-none pointer-events-auto transition-transform duration-200 ease-out will-change-transform hover:scale-[1.08] hover:-translate-y-2"/></div>
    </div>
  </div>
</section>

		<section class="max-w-6xl mx-auto mb-12 py-10 relative px-4">
			<h1 class="text-center font-karim text-5xl sm:text-6xl md:text-[8.5rem] mb-0 md:mb-0 leading-tight break-words">previous events</h1>
				
			<div id="events-scroll-container" class="w-screen relative left-1/2 -translate-x-1/2 overflow-x-auto overflow-y-hidden snap-x snap-mandatory no-scrollbar py-4">

	<div id="events-track" class="flex gap-6 md:gap-12 w-max items-start">

		<div class="w-[88vw] sm:w-[85vw] md:w-[800px] shrink-0 snap-center flex flex-col items-center md:-rotate-2 relative pb-48 sm:pb-56 md:pb-60">
			<a href="https://daydream.hackclub.com" class="w-full shadow-xl">
				<img src="new-images/daydream.webp" alt="Daydream" class="w-full aspect-[3/2] object-cover bg-black block" />
			</a>
			<div class="absolute inset-x-0 bottom-6 md:bottom-8 h-40 md:h-44 flex items-center justify-center px-2">
				<a href="https://daydream.hackclub.com" class="h-full inline-flex items-center justify-center flex-col gap-4">
					<img src="new-images/daydream-logo.webp" alt="Daydream Logo" class="max-h-full w-auto max-w-[65%] object-contain">
					<h1 class="text-sm md:text-lg w-[95%]">100 high school game jams in 100 cities simultaneously</h1>
				</a>
			</div>
		</div>

		<div class="w-[88vw] sm:w-[85vw] md:w-[800px] shrink-0 snap-center flex flex-col items-center md:-rotate-2 relative pb-48 sm:pb-56 md:pb-60">
			<a href="https://shipwrecked.hackclub.com" class="w-full shadow-xl">
				<img src="new-images/shipwrecked.webp" alt="Shipwrecked" class="w-full aspect-[3/2] object-cover bg-black block" />
			</a>
			<div class="absolute inset-x-0 bottom-6 md:bottom-8 h-40 md:h-44 flex items-center justify-center px-2">
				<a href="https://shipwrecked.hackclub.com" class="h-full inline-flex items-center justify-center flex-col gap-2">
					<img src="new-images/shipwrecked-logo.webp" alt="Shipwrecked Logo" class="max-h-full w-auto max-w-[65%] object-contain">
					<h1 class="text-sm md:text-lg w-full">A 4-day hackathon on a private island in Boston</h1>
				</a>
			</div>
		</div>

		<div class="w-[88vw] sm:w-[85vw] md:w-[800px] shrink-0 snap-center flex flex-col items-center md:-rotate-2 relative pb-48 sm:pb-56 md:pb-60">
			<a href="https://parthenon.hackclub.com" class="w-full shadow-xl">
				<img src="new-images/parthenon.webp" alt="Parthenon" class="w-full aspect-[3/2] object-cover bg-black block" />
			</a>
			<div class="absolute inset-x-0 bottom-6 md:bottom-8 h-40 md:h-44 flex items-center justify-center px-2">
				<a href="https://parthenon.hackclub.com" class="h-full inline-flex items-center justify-center flex-col gap-4">
					<img src="new-images/parthenon-logo.webp" alt="Parthenon Logo" class="max-h-full w-auto max-w-[65%] object-contain">
					<h1 class="text-sm md:text-lg w-[95%]">150 girls went to an all-girl hackathon in NYC</h1>
				</a>
			</div>
		</div>

		<div class="w-[88vw] sm:w-[85vw] md:w-[800px] shrink-0 snap-center flex flex-col items-center md:-rotate-2 relative pb-48 sm:pb-56 md:pb-60">
			<a href="https://overglade.hackclub.com" class="w-full shadow-xl">
				<img src="new-images/overglade.webp" alt="Overglade" class="w-full aspect-[3/2] object-cover bg-black block" />
			</a>
			<div class="absolute inset-x-0 bottom-6 md:bottom-8 h-40 md:h-44 flex items-center justify-center px-2">
				<a href="https://overglade.hackclub.com" class="h-full inline-flex items-center justify-center flex-col gap-4">
					<img src="new-images/overglade-logo.webp" alt="Overglade Logo" class="max-h-full w-auto max-w-[65%] object-contain">
					<h1 class="text-sm md:text-lg w-[95%]">65 teens gathered for a hyper-immersive game jam in Singapore</h1>
				</a>
			</div>
		</div>

		<div class="w-[88vw] sm:w-[85vw] md:w-[800px] shrink-0 snap-center flex flex-col items-center md:-rotate-2 relative pb-48 sm:pb-56 md:pb-60">
			<a href="https://undercity.hackclub.com" class="w-full shadow-xl">
				<img src="new-images/undercity.webp" alt="Undercity" class="w-full aspect-[3/2] object-cover bg-black block" />
			</a>
			<div class="absolute inset-x-0 bottom-6 md:bottom-8 h-40 md:h-44 flex items-center justify-center px-2">
				<a href="https://undercity.hackclub.com" class="h-full inline-flex items-center justify-center flex-col gap-4">
					<img src="new-images/undercity-logo.webp" alt="Undercity Logo" class="max-h-full w-auto max-w-[65%] object-contain">
					<h1 class="text-sm md:text-lg w-[95%]">A 4-day hardware hackathon in GitHub HQ, San Francisco</h1>
				</a>
			</div>
		</div>

		<div class="w-[88vw] sm:w-[85vw] md:w-[800px] shrink-0 snap-center flex flex-col items-center md:-rotate-2 relative pb-48 sm:pb-56 md:pb-60">
			<a href="https://juice.hackclub.com" class="w-full shadow-xl">
				<img src="new-images/juice.webp" alt="Juice" class="w-full aspect-[3/2] object-cover bg-black block" />
			</a>
			<div class="absolute inset-x-0 bottom-6 md:bottom-8 h-40 md:h-44 flex items-center justify-center px-2">
				<a href="https://juice.hackclub.com" class="h-full inline-flex items-center justify-center flex-col gap-4">
					<img src="new-images/juice-logo.webp" alt="Juice Logo" class="max-h-full w-auto max-w-[65%] object-contain">
					<h1 class="text-sm md:text-lg w-[95%]">100 teenagers ran a popup games cafe in Shanghai for a week</h1>
				</a>
			</div>
		</div>

	</div>
</div>
		</section>

		<img src="/cats.webp" alt="Cats" class="cat-click mx-auto mb-6 md:mb-2" data-meow tabindex="0" />
		<audio id="meow-audio" preload="auto">
			<source src="/audio/meow.mp3" type="audio/mpeg" />
		</audio>

		<script>
			import { initEventsScroll } from '../scripts/events-scroll';
			import { initMeow } from '../scripts/meow';

			initEventsScroll();
			initMeow();
		</script>

		<section class="bg-black text-white py-10 px-4 pt-0 relative">
			<h1 class="text-center font-karim text-5xl sm:text-6xl md:text-[8.5rem] mb-10 md:mb-8 break-words">FAQs</h1>
			<img src="/asset2.webp" class="hidden md:block absolute w-[25%] right-5 bottom-[300px] shake-on-hover" alt="horus" tabindex="0">			
			<div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-x-8 md:gap-x-16 gap-y-12 text-left">				<div class="flex flex-col gap-y-10 md:gap-y-12">
					<div>
						<h2 class="font-karim text-3xl md:text-5xl font-bold mb-3">What is Hack Club?</h2>
						<p class="font-futura text-lg md:text-2xl font-normal leading-tight">
							Hack Club is a global 501(c)(3) nonprofit based in the United States built by teens to support teen coders and we’ve run 500+ hackathons and events worldwide online and in-person.
						</p>
					</div>
					<div>
						<h2 class="font-karim text-3xl md:text-5xl font-bold mb-3">Who can attend?</h2>
						<p class="font-futura text-lg md:text-2xl font-normal leading-tight">
							Teenagers aged 13–18 from any part of the world!
						</p>
					</div>
					<div>
						<h2 class="font-karim text-3xl md:text-5xl font-bold mb-3">How do stipends work?</h2>
						<p class="font-futura text-lg md:text-2xl font-normal leading-tight">
							For each additional hour you code you get $8.5 US Dollars credits which can be used to purchase flight stipends. So if you code 20 more hours thats 20 hours x $8.5/hour = $170
						</p>
					</div>
				</div>

				<div class="flex flex-col gap-y-10 md:gap-y-12 relative">
<div class="absolute left-[-32px] top-0 bottom-0 w-px bg-white/20 hidden md:block"></div>					<div>
						<h2 class="font-karim text-3xl md:text-5xl font-bold mb-3">How do I qualify?</h2>
						<p class="font-futura text-lg md:text-2xl font-normal leading-tight">
							There are 3 simple steps:<br>
							1. Sign up via Horizons<br>
							2. Code for 35+ hours<br>
							3. You're qualified!
						</p>
					</div>
					<div>
						<h2 class="font-karim text-3xl md:text-5xl font-bold mb-3">Where can I find travel information?</h2>
						<p class="font-futura text-lg md:text-2xl font-normal leading-tight">
							We'll have a travel guide with visa, flight and arrival/departure details added here before June :)
						</p>
					</div>
					<div>
						<h2 class="font-karim text-3xl md:text-5xl font-bold mb-3">I have more questions</h2>
						<p class="font-futura text-lg md:text-2xl font-normal leading-tight">
							You can reach out to us via equinox@horizons.hackclub.com or have a Zoom call with one of the organisers :)
						</p>
					</div>
				</div>
			</div>
		</section>



		<section class="w-full flex flex-col items-center mb-16 md:mb-24">
			<img src="/asset3.webp" alt="footer decoration" class="relative z-20 w-full max-w-[600px] md:max-w-none md:w-[50%] mt-6 mb-4 md:mb-8 px-4"/>
  <p class="font-futura text-lg sm:text-xl md:text-4xl leading-snug md:leading-tight text-center px-4 sm:px-8 md:px-16 max-w-4xl">
    Create something new, get to see the pyramids of Giza up-close, code with new friends,
    ride a cruise down the Nile, and get immersed in Egyptian culture all in the span of 3 days!
  </p>

  <a href="https://horizons.hackclub.com?utm_source=equinoxsite" target="_blank" rel="noopener noreferrer" class="pointer-events-auto transition-transform duration-200 ease-out will-change-transform hover:scale-[1.08]">
    <img src="/calltoaction1.webp" alt="sign up" class="relative z-20 w-[50%] sm:w-[40%] max-w-[520px] md:w-[50%] mx-auto mt-10 sm:mt-16 md:mt-20"/>
  </a>
</section>

		<footer class="w-full">
  <div class="relative w-full overflow-hidden">
    <img
      src="/footer.webp"
      alt="footer bg decoration"
      class="hidden md:block absolute right-0 bottom-0 w-[80%] md:w-[72%] lg:w-[56%] z-0 pointer-events-none object-bottom-right"
    />
    <div class="relative z-10 min-h-[320px] md:min-h-[420px] lg:min-h-[520px] flex items-end">
      <div class="px-4 sm:px-6 pb-6 md:pb-12 max-w-200 text-left">
        <h1 class="font-karim text-4xl sm:text-5xl md:text-[8rem] leading-[0.9] md:leading-[0.8] mb-6 md:mb-10">
          See you in Egypt!
        </h1>
			<img src="/scarab.webp" alt="footer decoration" class="relative z-20 w-full max-w-[400px] md:max-w-none md:w-[50%] px-5 md:px-5" />
        <p class="font-futura text-xl md:text-3xl leading-tight mt-10">
          made with &lt;3  by teens @ hack club
        </p>
        <p class="font-futura text-base md:text-xl mt-2 text-white/80 leading-snug">
          hack club is a 501(c)(3) nonprofit built by teens for teens.
        </p>
      </div>
    </div>
  </div>
</footer>

	</main>
</Layout>